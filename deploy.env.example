# 遠端 Socket 後端（不要尾隨 /）
# VITE_SOCKET_URL=https://your-service.onrender.com

# --- 本機只跑前端、連 Render 後端（例：pocketmonster-pk52.onrender.com）---
# 在專案根目錄建立 .env.local（勿提交版控），內容一行即可：
#   VITE_SOCKET_URL=https://pocketmonster-pk52.onrender.com
# 然後： npm run dev:client
#
# 或單次指令（zsh/bash）：
#   VITE_SOCKET_URL=https://pocketmonster-pk52.onrender.com npm run dev:client

# --- 靜態打包、對戰連遠端 API ---
#   export VITE_SOCKET_URL=https://your-service.onrender.com
#   npm run build

# --- 選填：意見回饋（頂欄按鈕）---
# VITE_FEEDBACK_URL=https://docs.google.com/forms/...
# VITE_FEEDBACK_EMAIL=p4774756@gmail.com

# --- 選填：Firebase 好友（獨立「好友」頁；六項皆需設定）---
# 見 docs/FIREBASE_FRIENDS.md、docs/firebase-friends.rules、根目錄 firestore.indexes.json（含選用 cloud_pet_saves 養成備份規則）
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
