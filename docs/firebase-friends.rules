rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function pairKey(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function friendTokenData(pairId) {
      return get(/databases/$(database)/documents/friend_accept_tokens/$(pairId)).data;
    }

    match /profiles/{userId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == userId
          || exists(/databases/$(database)/documents/friends/$(pairKey(request.auth.uid, userId)))
        );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    /* 選用：登入後手動上傳／下載養成 JSON（每 uid 一筆；僅本人讀寫）。 */
    match /cloud_pet_saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /friend_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /friend_requests/{reqId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['fromUid', 'toUid', 'status', 'fromDisplayName']);
      allow delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow update: if false;
    }

    /* 邀請成立時寫入；接受好友時刪除。僅 toUid 可建立對應 friends 文件（見 friends allow create）。 */
    match /friend_accept_tokens/{pairId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.fromUid is string
        && request.resource.data.toUid is string
        && request.resource.data.fromUid != request.resource.data.toUid
        && pairId == pairKey(request.resource.data.fromUid, request.resource.data.toUid)
        && request.resource.data.keys().hasAll(['fromUid', 'toUid', 'fromDisplayName', 'requestId'])
        && request.resource.data.keys().hasOnly(['fromUid', 'toUid', 'fromDisplayName', 'requestId'])
        && request.resource.data.requestId is string
        && request.resource.data.fromDisplayName is string
        && request.resource.data.fromDisplayName.size() <= 32
        && exists(/databases/$(database)/documents/friend_requests/$(request.resource.data.requestId))
        && get(/databases/$(database)/documents/friend_requests/$(request.resource.data.requestId)).data.fromUid == request.resource.data.fromUid
        && get(/databases/$(database)/documents/friend_requests/$(request.resource.data.requestId)).data.toUid == request.resource.data.toUid
        && get(/databases/$(database)/documents/friend_requests/$(request.resource.data.requestId)).data.status == 'pending'
        && !exists(/databases/$(database)/documents/friends/$(pairId));
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      allow update: if false;
    }

    match /friends/{pairId} {
      /* Allow get when pair doc is missing (client checks !exists before create). */
      allow read: if request.auth != null
        && (
          !exists(/databases/$(database)/documents/friends/$(pairId))
          || request.auth.uid in resource.data.members
        );
      /* 僅受邀方（token.toUid）可建立；須與 friend_accept_tokens 及對應之 pending 邀請一致。 */
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/friend_accept_tokens/$(pairId))
        && friendTokenData(pairId).toUid == request.auth.uid
        && pairId == pairKey(friendTokenData(pairId).fromUid, friendTokenData(pairId).toUid)
        && exists(/databases/$(database)/documents/friend_requests/$(friendTokenData(pairId).requestId))
        && get(/databases/$(database)/documents/friend_requests/$(friendTokenData(pairId).requestId)).data.status == 'pending'
        && get(/databases/$(database)/documents/friend_requests/$(friendTokenData(pairId).requestId)).data.fromUid == friendTokenData(pairId).fromUid
        && get(/databases/$(database)/documents/friend_requests/$(friendTokenData(pairId).requestId)).data.toUid == friendTokenData(pairId).toUid
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.resource.data.members[0] is string
        && request.resource.data.members[1] is string
        && request.resource.data.members[0] < request.resource.data.members[1]
        && pairId == request.resource.data.members[0] + '_' + request.resource.data.members[1]
        && request.resource.data.members.hasAll([friendTokenData(pairId).fromUid, friendTokenData(pairId).toUid])
        && request.resource.data.nicknames is map
        && request.resource.data.nicknames[friendTokenData(pairId).fromUid]
          == get(/databases/$(database)/documents/friend_requests/$(friendTokenData(pairId).requestId)).data.fromDisplayName
        && request.resource.data.nicknames[friendTokenData(pairId).toUid] is string
        && request.resource.data.nicknames[friendTokenData(pairId).toUid].size() <= 32
        && request.resource.data.keys().hasAll(['members', 'nicknames', 'since'])
        && request.resource.data.keys().hasOnly(['members', 'nicknames', 'since']);
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
      /* 僅允許更新自己的暱稱：不可改 members／since，不可改對方 nicknames 欄位。 */
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nicknames'])
        && request.resource.data.members == resource.data.members
        && request.resource.data.since == resource.data.since
        && request.resource.data.nicknames is map
        && (
          (
            request.auth.uid == resource.data.members[0]
            && request.resource.data.nicknames[resource.data.members[1]]
              == resource.data.nicknames[resource.data.members[1]]
            && request.resource.data.nicknames[resource.data.members[0]] is string
            && request.resource.data.nicknames[resource.data.members[0]].size() <= 32
          )
          || (
            request.auth.uid == resource.data.members[1]
            && request.resource.data.nicknames[resource.data.members[0]]
              == resource.data.nicknames[resource.data.members[0]]
            && request.resource.data.nicknames[resource.data.members[1]] is string
            && request.resource.data.nicknames[resource.data.members[1]].size() <= 32
          )
        );

      match /messages/{msgId} {
        /* 讀取：僅限父層好友對之成員（見 friends/{pairId}.members）。不依賴每則 memberUids，
           以免舊訊息缺欄位或型別異常時，onSnapshot 整批 permission-denied。
           建立訊息仍須寫入 memberUids（見 allow create）。 */
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/friends/$(pairId))
          && request.auth.uid in get(/databases/$(database)/documents/friends/$(pairId)).data.members;
        /* createdAt 使用 serverTimestamp() 時，keys() 可能不含 createdAt，故 hasOnly 分兩種寫法。
           text.size() 為 UTF-8 位元組數（與前端 FRIEND_CHAT_MAX_LEN=500 字元對齊之上限）。 */
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(['fromUid', 'text', 'memberUids'])
          && (
            request.resource.data.keys().hasOnly(['fromUid', 'text', 'memberUids'])
            || request.resource.data.keys().hasOnly(['fromUid', 'text', 'memberUids', 'createdAt'])
          )
          && request.resource.data.memberUids is list
          && request.resource.data.memberUids.size() == 2
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids == get(/databases/$(database)/documents/friends/$(pairId)).data.members
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow delete: if request.auth != null
          && exists(/databases/$(database)/documents/friends/$(pairId))
          && request.auth.uid in get(/databases/$(database)/documents/friends/$(pairId)).data.members;
        allow update: if false;
      }
    }
  }
}
