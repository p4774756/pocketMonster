rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /friend_codes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /friend_requests/{reqId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['fromUid', 'toUid', 'status', 'fromDisplayName']);
      allow delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow update: if false;
    }

    match /friends/{pairId} {
      /* Allow get when pair doc is missing (client checks !exists before create). */
      allow read: if request.auth != null
        && (
          !exists(/databases/$(database)/documents/friends/$(pairId))
          || request.auth.uid in resource.data.members
        );
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2;
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow update: if false;

      match /messages/{msgId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/friends/$(pairId)).data.members;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/friends/$(pairId)).data.members
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.keys().hasAll(['fromUid', 'text', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }
    }
  }
}
