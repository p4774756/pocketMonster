{
  "name": "pocket-pet-battle",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite --port 5173 --host",
    "build": "vite build",
    "strip-egg-bg": "node scripts/strip-egg-gray.mjs public/pets/pet-egg-volt.png public/pets/pet-egg-crystal.png public/pets/pet-egg-chicken.png",
    "strip-pet-matte": "node scripts/strip-creature-matte.mjs",
    "optimize:pets": "node scripts/optimize-pet-pngs.mjs",
    "start": "NODE_ENV=production node server/index.js",
    "start:api": "SERVE_STATIC=0 NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "concurrently": "^9.1.2",
    "sharp": "^0.33.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.3"
  }
}
